# SPDX-License-Identifier: MIT-0
# scspell-id: a4da0d78-4432-11f1-8f3f-80ee73e9b8e7

root = true

[*.{c,sh}]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
max_line_length = 80
trim_trailing_whitespace = true

[Makefile*]
charset = utf-8
end_of_line = lf
indent_style = tab
insert_final_newline = true
max_line_length = 80
trim_trailing_whitespace = true

[README.md]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true
